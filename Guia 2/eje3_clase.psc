Algoritmo eje3_clase
	Definir letra Como Caracter
	Escribir Sin Saltar "Ingrese su nota: "
	Leer letra
	Segun letra Hacer
		"A":
			Escribir "Excelente"
		"B":
			Escribir "Bueno"
		"C":
			Escribir "Regular"
		"D":
			Escribir "Deficiente"
		"F":
			Escribir "reprobado"
		De Otro Modo:
			Escribir "Ingrese una letra valida"
			
	Fin Segun
	
FinAlgoritmo
