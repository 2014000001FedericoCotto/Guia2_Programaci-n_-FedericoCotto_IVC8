Algoritmo Eje4_en_clase
	Definir desi Como Entero
	Escribir "Que de desea? Tenemos: "
	Escribir "1 Hamburguesa"
	Escribir "2 Pizza"
	Escribir "3 Pollo Frito"
	Escribir "4 Ensalada"
	
	Leer desi
	Segun desi Hacer
		1:
			Escribir "Hamburguesa, la clasica"
		2:
			Escribir "Pizza, tiene familia?"
		3:
			Escribir "Pollo frito, buena desición"
			
			
		4:
			Escribir "Ensalada"
		De Otro Modo:
			Escribir "Lo siento no tenemos eso en el menú"
	Fin Segun
	
	
FinAlgoritmo
